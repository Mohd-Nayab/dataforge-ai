PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local development
PYTHON_SERVICE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:5173

# Production (Render example)
# PYTHON_SERVICE_URL=https://dataforge-python.onrender.com
# CORS_ORIGIN=https://dataforge-ai.vercel.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Database options: json (default) | sqlite | postgres | mongodb
DATABASE_TYPE=json
DATA_DIR=./data
# postgres:  postgresql://user:pass@host:5432/dbname
# mongodb:   mongodb+srv://user:pass@cluster.mongodb.net/dbname
DATABASE_URL=
